{
  "name": "focusdaw-studio",
  "version": "1.18.9",
  "description": "Stem mixing DAW \uD83C\uDDE5\uD83C\uDDF7Electron desktop app",
  "main": "electron/main.js",
  "scripts": {
    "build:renderers": "node scripts/build-renderers.js",
    "start": "npm run build:renderers && electron .",
    "benchmark:stretch": "node tools/time-stretch-benchmark/benchmark.js",
    "dist:mac": "npm run build:renderers && electron-builder --mac",
    "dist:win": "npm run build:renderers && electron-builder --win",
    "dist:linux": "npm run build:renderers && electron-builder --linux"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "lamejs": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "soundtouchjs": "^0.3.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.focusdaw.studio",
    "productName": "FocusDAW Studio",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "build/*.js",
      "build/vendor/**/*",
      "manual/live-screens/**/*",
      "studio.html",
      "mixer.html",
      "advanced-pan.html",
      "advanced-ambience.html",
      "advanced-eq.html",
      "help.html",
      "version.js",
      "meyda.min.js",
      "audio-engine.js",
      "audio-bridge.js",
      "ui-kit.jsx",
      "ui-tracks.jsx",
      "ui-mixer.jsx",
      "ui-dialogs.jsx",
      "ui-help.jsx",
      "advanced-pan-app.jsx",
      "advanced-ambience-app.jsx",
      "advanced-eq-app.jsx",
      "app.jsx",
      "mixer-app.jsx",
      "bin/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "bin/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Audio"
    }
  },
  "allowScripts": {
    "electron@42.4.0": true,
    "ffmpeg-static@5.3.0": true
  }
}
