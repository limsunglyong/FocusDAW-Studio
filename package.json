{
  "name": "focusdaw-studio",
  "version": "1.4.1",
  "description": "Stem mixing DAW — Electron desktop app",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "benchmark:stretch": "node tools/time-stretch-benchmark/benchmark.js",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.focusdaw.studio",
    "productName": "FocusDAW Studio",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "manual/live-screens/**/*",
      "studio.html",
      "mixer.html",
      "help.html",
      "version.js",
      "audio-engine.js",
      "ui-kit.jsx",
      "ui-tracks.jsx",
      "ui-mixer.jsx",
      "ui-dialogs.jsx",
      "ui-help.jsx",
      "app.jsx",
      "mixer-app.jsx"
    ],
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Audio"
    }
  },
  "allowScripts": {
    "electron@42.4.0": true,
    "ffmpeg-static@5.3.0": true
  }
}
